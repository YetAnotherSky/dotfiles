[global]

monitor = 0
follow = mouse
width = 360
height = 300
origin = top-right

offset = 20x52

notification_limit = 8

transparency = 15
corner_radius = 0
frame_width = 2
separator_height = 2

padding = 14
horizontal_padding = 14
text_icon_padding = 10

font = JetBrainsMono Nerd Font 11
markup = full
format = "<b>%s</b>\n%b"

icon_position = left
min_icon_size = 32
max_icon_size = 64

sort = yes
stack_duplicates = true
hide_duplicate_count = false
sticky_history = yes
history_length = 20

mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all

background = "#2E3440CC"
foreground = "#ECEFF4"
frame_color = "#81A1C1"
separator_color = frame

progress_bar = true
progress_bar_height = 8
progress_bar_frame_width = 1
progress_bar_min_width = 120
progress_bar_max_width = 300

idle_threshold = 120
show_age_threshold = 60
word_wrap = yes
ellipsize = middle
ignore_newline = no

[urgency_low]
timeout = 4
background = "#2E3440CC"
foreground = "#D8DEE9"
frame_color = "#88C0D0"

[urgency_normal]
timeout = 7
background = "#3B4252CC"
foreground = "#ECEFF4"
frame_color = "#81A1C1"

[urgency_critical]
timeout = 0
background = "#BF616ACC"
foreground = "#ECEFF4"
frame_color = "#D08770"
